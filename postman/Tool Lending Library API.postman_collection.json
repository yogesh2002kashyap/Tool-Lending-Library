{
  "info": {
    "_postman_id": "8f3e2c19-9c75-4bd5-a2d8-66f740ef05b0",
    "name": "Tool Lending Library API",
    "description": "Postman collection for validating the Tool Lending Library API CRUD endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tools",
      "description": "Tool resource CRUD requests.",
      "item": [
        {
          "name": "Create Tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"toolName\": \"Cordless Drill\",\n  \"category\": \"Power Tools\",\n  \"condition\": \"Good\",\n  \"status\": \"Available\",\n  \"borrower\": \"Jordan Miles\",\n  \"description\": \"Compact drill with two batteries and a carrying case.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tools",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tools"
              ]
            },
            "description": "Creates a tool and stores the returned `_id` in the `toolId` environment variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response time is under 1000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const tool = pm.response.json();",
                  "",
                  "pm.test('Response includes required tool fields', function () {",
                  "  pm.expect(tool).to.include.keys('_id', 'toolName', 'category', 'condition', 'status', 'borrower', 'description', 'createdAt', 'updatedAt');",
                  "});",
                  "",
                  "pm.test('Tool ID is returned and saved', function () {",
                  "  pm.expect(tool._id).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('toolId', tool._id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Tools",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tools",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tools"
              ]
            },
            "description": "Retrieves all tools."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is under 1000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const tools = pm.response.json();",
                  "",
                  "pm.test('Response body is an array', function () {",
                  "  pm.expect(tools).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Returned tools include required fields when present', function () {",
                  "  tools.forEach(function (tool) {",
                  "    pm.expect(tool).to.include.keys('_id', 'toolName', 'category', 'condition', 'status', 'borrower', 'description', 'createdAt', 'updatedAt');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Tool By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tools/{{toolId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tools",
                "{{toolId}}"
              ]
            },
            "description": "Retrieves the tool identified by the `toolId` environment variable."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('toolId')) {",
                  "  throw new Error('Missing toolId. Run Create Tool first or set the toolId environment variable.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is under 1000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const tool = pm.response.json();",
                  "",
                  "pm.test('Response includes required tool fields', function () {",
                  "  pm.expect(tool).to.include.keys('_id', 'toolName', 'category', 'condition', 'status', 'borrower', 'description', 'createdAt', 'updatedAt');",
                  "});",
                  "",
                  "pm.test('Returned tool matches environment toolId', function () {",
                  "  pm.expect(tool._id).to.eql(pm.environment.get('toolId'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Tool",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Borrowed\",\n  \"borrower\": \"Riley Chen\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tools/{{toolId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tools",
                "{{toolId}}"
              ]
            },
            "description": "Updates the tool identified by the `toolId` environment variable."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('toolId')) {",
                  "  throw new Error('Missing toolId. Run Create Tool first or set the toolId environment variable.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const tool = pm.response.json();",
                  "",
                  "pm.test('Response includes required tool fields', function () {",
                  "  pm.expect(tool).to.include.keys('_id', 'toolName', 'category', 'condition', 'status', 'borrower', 'description', 'createdAt', 'updatedAt');",
                  "});",
                  "",
                  "pm.test('Tool was updated', function () {",
                  "  pm.expect(tool._id).to.eql(pm.environment.get('toolId'));",
                  "  pm.expect(tool.status).to.eql('Borrowed');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Tool",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tools/{{toolId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tools",
                "{{toolId}}"
              ]
            },
            "description": "Deletes the tool identified by the `toolId` environment variable."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('toolId')) {",
                  "  throw new Error('Missing toolId. Run Create Tool first or set the toolId environment variable.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const result = pm.response.json();",
                  "",
                  "pm.test('Response confirms deletion', function () {",
                  "  pm.expect(result).to.have.property('message', 'Tool deleted successfully');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "toolId",
      "value": ""
    }
  ]
}
